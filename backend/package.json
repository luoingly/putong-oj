{
  "name": "@putongoj/backend",
  "version": "3.0.0",
  "private": true,
  "main": "app.ts",
  "engines": {
    "node": ">= 22.0.0"
  },
  "scripts": {
    "build": "tsc && cp -r src/scripts dist/scripts",
    "coverage": "nyc report --reporter=text-lcov > coverage.lcov",
    "deploy:init": "cross-env NODE_ENV=production node setup.js",
    "deploy:start": "npx pm2 start pm2.config.json",
    "dev": "concurrently \"npm run dev:app\" \"npm run dev:ws\" \"npm run dev:updater\" \"npm run dev:worker\"",
    "dev:app": "cross-env NODE_ENV=development nodemon -e ts,js --exec ts-node src/app.ts",
    "dev:updater": "cross-env NODE_ENV=development nodemon -e ts,js --exec ts-node src/jobs/updater.ts",
    "dev:worker": "cross-env NODE_ENV=development nodemon -e ts,js --exec ts-node src/jobs/worker.ts",
    "dev:ws": "cross-env NODE_ENV=development nodemon -e ts,js --exec ts-node src/ws.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "posttest": "cross-env NODE_ENV=test ts-node test/posttest.ts",
    "pretest": "cross-env NODE_ENV=test ts-node test/pretest.ts",
    "report": "nyc report --reporter=html",
    "start": "cross-env NODE_ENV=production node dist/app.js",
    "test": "cross-env-shell NODE_ENV=test \"ts-node test/pretest.ts && nyc ava && ts-node test/posttest.ts\"",
    "typecheck": "tsc --noEmit --skipLibCheck"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "@noble/ciphers": "^2.1.1",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@putongoj/shared": "workspace:*",
    "@zip.js/zip.js": "^2.8.26",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "fast-levenshtein": "^3.0.0",
    "fs-extra": "^11.3.4",
    "hono": "^4.12.14",
    "ioredis": "^5.10.1",
    "lodash": "^4.18.1",
    "luxon": "^3.7.2",
    "mongoose": "^9.4.1",
    "mongoose-paginate-v2": "^1.9.4",
    "node-cache": "^5.1.2",
    "pm2": "^6.0.14",
    "superagent": "^10.3.0",
    "tracer": "^1.3.0",
    "uuid": "^13.0.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.1.1",
    "@ava/typescript": "^6.0.0",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.12.2",
    "@types/superagent": "^8.1.9",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "ava": "^7.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "nodemon": "^3.1.14",
    "nyc": "^18.0.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "nodemonConfig": {
    "ignore": [
      "data/*",
      "dist/*",
      "test/*"
    ]
  },
  "ava": {
    "concurrency": 1,
    "environmentVariables": {
      "NODE_ENV": "test"
    },
    "extensions": [
      "ts",
      "js"
    ],
    "files": [
      "test/**/*.test.{js,ts}"
    ],
    "require": [
      "ts-node/register",
      "./test/_force-exit.mjs"
    ],
    "serial": true,
    "timeout": "30s"
  },
  "nyc": {
    "include": [
      "src/**/*.{js,ts}"
    ],
    "exclude": [
      "**/*.d.ts"
    ],
    "require": [
      "ts-node/register"
    ]
  }
}
